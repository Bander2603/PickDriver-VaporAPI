# Test profile (used by swift test)
JWT_SECRET=test-secret
JWT_EXPIRES_IN_SECONDS=604800
APP_VERSION=test

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=pickdriver_test
DATABASE_USERNAME=pickdriver
DATABASE_PASSWORD=change-me
DATABASE_TLS_MODE=disable

# Explicitly disable drill DB settings in test profile
DRILL_DB_HOST=
DRILL_DB_PORT=
DRILL_DB_NAME=
DRILL_DB_USER=
DRILL_DB_USERNAME=
DRILL_DB_PASSWORD=
DRILL_DB_SSLMODE=
DRILL_DB_TLS_MODE=

# Optional social auth clients
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_ID=
APPLE_CLIENT_IDS=

# Email (test defaults)
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@pickdriver.cc
EMAIL_FROM_NAME=PickDriver
EMAIL_VERIFICATION_LINK_BASE_URL=http://localhost:3000/api/auth/verify-email-link
EMAIL_VERIFICATION_SUCCESS_REDIRECT_URL=
PASSWORD_RESET_LINK_BASE_URL=http://localhost:3000/api/auth/reset-password-link
PASSWORD_RESET_REDIRECT_URL=
EMAIL_VERIFICATION_EXPIRATION_SECONDS=86400
EMAIL_VERIFICATION_RESEND_INTERVAL_SECONDS=0
PASSWORD_RESET_EXPIRATION_SECONDS=3600
PASSWORD_RESET_RESEND_INTERVAL_SECONDS=0

ENABLE_INTERNAL_ROUTES=true
INTERNAL_SERVICE_TOKEN=test-internal-token
MAINTENANCE_MODE=false
INTERNAL_REQUIRE_HTTPS=false

